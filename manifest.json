{
  "manifest_version": 3,
  "name": "Annotated",
  "version": "1.0.0",
  "description": "Clip and annotate any content from the web.",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Annotated"
  }
}
